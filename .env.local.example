OPENROUTER_API_KEY=

# Model slug from openrouter.ai/models (default: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional OpenRouter attribution headers
# OPENROUTER_SITE_URL=http://localhost:3000
# OPENROUTER_APP_NAME=Review Discovery Engine

# Set to true to use keyword-based demo classification (no API credits needed)
USE_MOCK_CLASSIFIER=true
