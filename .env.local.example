GROQ_API_KEY=

# Model from console.groq.com/docs/models (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Groq free-tier limits (llama-3.3-70b-versatile): 30 req/min, 1K req/day, 12K tok/min, 100K tok/day
# Real LLM classification fits ~100 reviews/day — use docs/review-corpus/sample100.csv for live runs.
# Optional throttling overrides (defaults tuned in lib/groq-limits.ts):
# GROQ_CLASSIFY_BATCH_SIZE=20
# GROQ_BATCH_DELAY_MS=60000

# Classifications are cached in Turso by content hash + model (re-runs skip Groq for known reviews).

# Live scrape — max reviews per source (default 1000, min 10)
# FETCH_MAX_REVIEWS_PER_SOURCE=1000

# Set to true to use keyword-based demo classification (no API credits needed)
# Also used automatically when Groq blocks your network (VPN/region/firewall).
USE_MOCK_CLASSIFIER=false

# Include per-review audit records in /api/classify responses
CLASSIFICATION_AUDIT=false

# Turso — Research Repository
# Remote (Turso cloud): libsql://your-db-name.turso.io
# Local dev (default if unset): file:data/research.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
