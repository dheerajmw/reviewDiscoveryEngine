# Provider: cerebras (default) or groq
LLM_PROVIDER=cerebras

CEREBRAS_API_KEY=

# Default for ReviewLens taxonomy classification (Cerebras free tier)
CEREBRAS_MODEL=gpt-oss-120b

# Optional Cerebras base URL override (default: https://api.cerebras.ai/v1)
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Match cloud.cerebras.ai → Limits for quota split UI (gpt-oss-120b defaults)
# LLM_DAILY_TOKEN_BUDGET=1000000
# LLM_REQUESTS_PER_DAY=2400

# Optional throttling overrides (defaults tuned in lib/llm-limits.ts):
LLM_CLASSIFY_BATCH_SIZE=10
# Omit LLM_BATCH_DELAY_MS to auto-compute from 5 RPM + 30K TPM on Cerebras.

# --- Groq (set LLM_PROVIDER=groq) ---
# GROQ_API_KEY=
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# LLM_DAILY_TOKEN_BUDGET=500000
# LLM_REQUESTS_PER_DAY=1000

# Classifications are cached in Turso by content hash + model (re-runs skip LLM for known reviews).

# Live scrape — max reviews per source (default 1000, min 10)
# FETCH_MAX_REVIEWS_PER_SOURCE=1000

# Set to true to use keyword-based demo classification (no API credits needed)
# Also used automatically when the LLM cannot be reached (auth/network errors).
USE_MOCK_CLASSIFIER=false

# Include per-review audit records in /api/classify responses
CLASSIFICATION_AUDIT=false

# Turso — Research Repository
# Remote (Turso cloud): libsql://your-db-name.turso.io
# Local dev (default if unset): file:data/research.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
